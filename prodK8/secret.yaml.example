# Manual secret creation (NOT recommended for production)
# Use external-secret.yaml with External Secrets Operator instead
#
# To use this file:
# 1. Copy to secret.yaml
# 2. Replace the password value
# 3. kubectl apply -f secret.yaml
#
apiVersion: v1
kind: Secret
metadata:
  name: twc-recommendations-secrets
  namespace: recommendations
type: Opaque
stringData:
  CLICKHOUSE_PASSWORD: "REPLACE_WITH_ACTUAL_PASSWORD"
